# Clé API utilisée pour les appels à l'API Brixhub
API_KEY=YOUR_API_KEY_HERE

# Token pour connecter le bot Discord
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Ports utilisés pour héberger l'application Flask
PORT=10000

# Variables pour les identifiants des canaux dans le bot Discord
SEARCH_CHANNEL_ID=YOUR_SEARCH_CHANNEL_ID_HERE
RESULTS_CHANNEL_ID=YOUR_RESULTS_CHANNEL_ID_HERE

# Base URL pour les appels dans l'application
BASE_URL=https://mikami-justice.onrender.com
